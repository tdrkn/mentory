@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()
title Mentory — L1 System Context (MVP)

' ============================================================
' ОБОСНОВАНИЯ ВЫБОРА ГРАНИЦ СИСТЕМЫ
' ============================================================
' Контекстная диаграмма построена на основе:
'   — USM (product/usm.txt): три актора — Менти, Ментор, Администратор;
'   — ФТ FR1–FR22: регистрация, профиль, поиск, бронирование, оплата,
'     чат, видеозвонки, жалобы, модерация, выплаты;
'   — НФТ NFR14: доступность 99.9%, что подразумевает надёжную
'     внешнюю интеграцию с платёжной системой и email-сервисом;
'   — НФТ NFR16: уведомления push + email → внешний Email-сервис;
'   — ER: sessions, payments, payouts → необходимость внешнего эквайринга.
' ============================================================

' --- Акторы ---
' По USM и UC1-UC20: три роли пользователей
Person(mentee, "Менти", "Ищет ментора, записывается\nна сессию, оплачивает,\nоставляет отзыв.\n(US1-US9)")
Person(mentor, "Ментор", "Управляет профилем, услугами\nи расписанием. Проводит\nсессии, получает выплаты.\n(US1-US4, US10-US13)")
Person(admin, "Администратор", "Модерирует контент, верифицирует\nрегалии, обрабатывает жалобы,\nуправляет платежами.\n(US14-US16, FR17-FR22)")

' --- Система ---
System(mentory, "Платформа Mentory", "Веб-платформа для подбора\nменторов и проведения\nонлайн-консультаций.\nОбеспечивает полный цикл:\nпоиск → запись → оплата →\nсессия → отзыв.")

' --- Внешние системы ---
' FR9, FR22: оплата на стороннем сервисе эквайринга;
'   платёжные данные НЕ хранятся на стороне платформы (FR22).
' ER: payments.provider_payment_id, payouts.status
System_Ext(payment, "Платёжная система\n(Эквайринг)", "Обработка платежей, холдирование,\nвозвраты, выплаты менторам.\nПлатёжные данные карт хранятся\nтолько на стороне эквайринга.\n(FR9, FR15, FR22)")

' NFR16: уведомления push + email
' FR1: подтверждение email при регистрации
' UC1: верификация email
System_Ext(email, "Email-сервис\n(SMTP)", "Отправка писем: подтверждение\nрегистрации, сброс пароля,\nуведомления о сессиях.\n(FR1, NFR16)")

' FR5, FR6, UC4, UC11: видеозвонки для сессий
' ER: video_rooms.meeting_url
' В MVP — внешняя ссылка (Zoom/Meet/Teams);
' целевая модель — встроенный провайдер (FR6).
System_Ext(video, "Видео-провайдер\n(Zoom / Meet / встроенный)", "Проведение видеоконсультаций.\nВ MVP — через внешнюю ссылку\n(FR6, UC11, ER: video_rooms).")

' --- Связи ---
Rel(mentee, mentory, "Ищет менторов, бронирует\nслоты, оплачивает сессии,\nобщается в чате", "HTTPS")
Rel(mentor, mentory, "Управляет профилем,\nрасписанием, проводит\nсессии, выводит средства", "HTTPS")
Rel(admin, mentory, "Модерирует пользователей,\nверифицирует регалии,\nобрабатывает жалобы", "HTTPS")

Rel(mentory, payment, "Создаёт платёж, получает\nwebhook об оплате, инициирует\nвыплату ментору", "REST API")
Rel(mentory, email, "Отправляет транзакционные\nписьма: верификация, напоминания,\nуведомления", "SMTP")
Rel(mentory, video, "Создаёт видеокомнату,\nполучает ссылки для\nучастников", "REST API")

@enduml
