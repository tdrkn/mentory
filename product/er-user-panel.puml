@startuml

skinparam linetype ortho
top to bottom direction
skinparam defaultFontSize 12
skinparam ArrowFontSize 11
skinparam nodesep 70
skinparam ranksep 95

title Mentory ER (Юзер-панель / Core MVP, Must Have)

entity "users" as users {
  * id : Integer <<PK>>
  --
  email : text <<UQ>>
  password_hash : text
  full_name : text
  role : text
  status : text
  created_at : timestamp
}

entity "mentor_profiles" as mentor_profiles {
  * user_id : Integer <<PK, FK>>
  --
  headline : text <<nullable>>
  bio : text <<nullable>>
  is_active : bool
  rating_avg : numeric <<nullable>>
  rating_count : int <<nullable>>
}

entity "mentee_profiles" as mentee_profiles {
  * user_id : Integer <<PK, FK>>
  --
  background : text <<nullable>>
  goals : text[] <<nullable>>
}

entity "topics" as topics {
  * id : Integer <<PK>>
  --
  name : text <<UQ>>
}

entity "mentor_topics" as mentor_topics {
  * mentor_id : Integer <<PK, FK>>
  * topic_id : Integer <<PK, FK>>
}

entity "mentor_services" as mentor_services {
  * id : Integer <<PK>>
  --
  mentor_id : Integer <<FK>>
  title : text
  duration_min : int
  price_amount : numeric
  currency : text
  is_active : bool
}

entity "slots" as slots {
  * id : Integer <<PK>>
  --
  mentor_id : Integer <<FK>>
  start_at : timestamp
  end_at : timestamp
  status : text
}

entity "sessions" as sessions {
  * id : Integer <<PK>>
  --
  mentor_id : Integer <<FK>>
  mentee_id : Integer <<FK>>
  service_id : Integer <<FK>>
  slot_id : Integer <<FK>>
  status : text
  start_at : timestamp
  end_at : timestamp
  created_at : timestamp
  canceled_at : timestamp <<nullable>>
  cancel_reason : text <<nullable>>
}

entity "video_rooms" as video_rooms {
  * id : Integer <<PK>>
  --
  session_id : Integer <<FK>>
  meeting_url : text <<nullable>>
}

entity "conversations" as conversations {
  * id : Integer <<PK>>
  --
  mentor_id : Integer <<FK>>
  mentee_id : Integer <<FK>>
  session_id : Integer <<FK, nullable>>
  created_at : timestamp
}

entity "messages" as messages {
  * id : Integer <<PK>>
  --
  conversation_id : Integer <<FK>>
  sender_id : Integer <<FK>>
  content : text
  created_at : timestamp
  read_at : timestamp <<nullable>>
}

entity "payments" as payments {
  * id : Integer <<PK>>
  --
  session_id : Integer <<FK>>
  amount_cents : int
  currency : text
  status : text
  provider_payment_id : text <<nullable>>
  created_at : timestamp
}

entity "payouts" as payouts {
  * id : Integer <<PK>>
  --
  mentor_id : Integer <<FK>>
  amount_cents : int
  currency : text
  status : text
  created_at : timestamp
}

entity "reviews" as reviews {
  * id : Integer <<PK>>
  --
  session_id : Integer <<FK>>
  mentee_id : Integer <<FK>>
  mentor_id : Integer <<FK>>
  rating : int
  text : text <<nullable>>
  created_at : timestamp
}

entity "notifications" as notifications {
  * id : Integer <<PK>>
  --
  user_id : Integer <<FK>>
  type : text
  created_at : timestamp
  read_at : timestamp <<nullable>>
}

' layout
users -[hidden]down- mentor_profiles
users -[hidden]right- mentee_profiles
mentor_profiles -[hidden]down- mentor_topics
topics -[hidden]right- mentor_topics
mentor_profiles -[hidden]down- mentor_services
mentor_services -[hidden]down- slots
slots -[hidden]down- sessions
sessions -[hidden]left- reviews
sessions -[hidden]right- payments
sessions -[hidden]down- conversations
conversations -[hidden]down- messages
video_rooms -[hidden]left- sessions
payouts -[hidden]down- notifications

' relationships
users ||--o| mentor_profiles : "профиль ментора"
users ||--o| mentee_profiles : "профиль менти"
mentor_profiles ||--o{ mentor_topics : "экспертиза"
topics ||--o{ mentor_topics : "темы"

users ||--o{ mentor_services : "услуги"
users ||--o{ slots : "слоты"
mentor_services ||--o{ sessions : "услуга"
slots ||--o| sessions : "слот"
users ||--o{ sessions : "участие"

sessions ||--o| payments : "оплата"
sessions ||--o| video_rooms : "видеокомната"
sessions ||--o| reviews : "отзыв"
sessions ||--o| conversations : "чат"
conversations ||--o{ messages : "сообщения"

users ||--o{ payouts : "выплаты"
users ||--o{ notifications : "уведомления"

legend right
  PK - основной идентификатор
  FK - ссылка на связанную запись
  UQ - уникальное значение
endlegend

@enduml
